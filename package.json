{
    "name": "afk-best",
    "version": "2.0.0",
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "build": "ng build --configuration development",
        "build:prod": "ng build && yarn run copy-assets && yarn run cleanup-assets",
        "watch": "ng build --watch --configuration development",
        "test": "ng test",
        "test:ci": "ng test --browsers=ChromeHeadlessCI --watch=false --progress=false",
        "lint": "ng lint",
        "i18n": "ng extract-i18n --output-path src/locale",
        "copy-assets": "cp dist/afk-best/en/*.ico dist/afk-best/en/*.xml dist/afk-best/en/*.txt dist/afk-best/en/_redirects dist/afk-best/",
        "cleanup-assets": "rm -f dist/afk-best/*/*.ico dist/afk-best/*/*.xml dist/afk-best/*/*.txt dist/afk-best/*/_redirects"
    },
    "private": true,
    "dependencies": {
        "@angular/common": "^21.2.1",
        "@angular/compiler": "^21.2.1",
        "@angular/core": "^21.2.1",
        "@angular/forms": "^21.2.1",
        "@angular/localize": "^21.2.1",
        "@angular/platform-browser": "^21.2.1",
        "@angular/platform-browser-dynamic": "^21.2.1",
        "@angular/router": "^21.2.1",
        "@fortawesome/angular-fontawesome": "^4.0.0",
        "@fortawesome/fontawesome-svg-core": "^7.2.0",
        "@fortawesome/free-brands-svg-icons": "^7.2.0",
        "@fortawesome/free-solid-svg-icons": "^7.2.0",
        "@ngneat/until-destroy": "^10.0.0",
        "bootstrap": "^5.3.8",
        "ngx-comentario": "~0.6.0",
        "rxjs": "^7.8.2",
        "tslib": "^2.8.1"
    },
    "devDependencies": {
        "@angular-devkit/build-angular": "^21.2.1",
        "@angular-eslint/builder": "^21.3.0",
        "@angular-eslint/eslint-plugin": "^21.3.0",
        "@angular-eslint/eslint-plugin-template": "^21.3.0",
        "@angular-eslint/schematics": "^21.3.0",
        "@angular-eslint/template-parser": "^21.3.0",
        "@angular/cli": "^21.2.1",
        "@angular/compiler-cli": "^21.2.1",
        "@eslint/js": "^9.39.4",
        "@types/jasmine": "^6.0.0",
        "@typescript-eslint/eslint-plugin": "^8.56.1",
        "@typescript-eslint/parser": "^8.56.1",
        "@typescript-eslint/types": "^8.56.1",
        "@typescript-eslint/utils": "^8.56.1",
        "angular-eslint": "^21.3.0",
        "eslint": "^9.39.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jsdoc": "^62.7.1",
        "eslint-plugin-mocha": "^11.2.0",
        "eslint-plugin-no-only-tests": "^3.3.0",
        "eslint-plugin-prefer-arrow": "^1.2.3",
        "eslint-scope": "^9.1.2",
        "jasmine-core": "^6.1.0",
        "karma": "^6.4.4",
        "karma-chrome-launcher": "^3.2.0",
        "karma-coverage": "^2.2.1",
        "karma-jasmine": "^5.1.0",
        "karma-jasmine-html-reporter": "^2.2.0",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.56.1",
        "vite": "^7.3.1"
    },
    "packageManager": "yarn@4.9.4"
}
